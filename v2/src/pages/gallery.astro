---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Picture from "../components/Picture.astro";

const photos = [
  { src: "cellar.jpg", caption: "The wine cellar at Adare Manor", year: "2024" },
  { src: "cms intro.jpeg", caption: "CMS Introductory Certificate, Madrid", year: "2024" },
  { src: "ch indoors.jpg", caption: "The Carriage House interior", year: "2024" },
  { src: "ch outdoors.jpg", caption: "The Carriage House at dusk", year: "2024" },
  { src: "waitering.jpg", caption: "New dish at The Mustard Seed", year: "2023" },
  { src: "agency work.jpg", caption: "Agency work at The Great Southern, Killarney", year: "2023" },
  { src: "lib desk.jpg", caption: "Peer Advisor desk, Glucksman Library", year: "2024" },
  { src: "ulsl work.jpg", caption: "Raising funds for UL Student Life", year: "2023" },
  { src: "ul in winter.jpg", caption: "The University of Limerick in winter", year: "2024" },
  { src: "pc build.jpg", caption: "A PC build in progress", year: "2023" },
  { src: "vines in bg.jpg", caption: "Vines along the Danube, Northern Bulgaria", year: "2024" },
  { src: "graduation.jpg", caption: "Secondary school graduation", year: "2022" },
  { src: "leaving cert.jpg", caption: "Leaving Cert construction project (H1)", year: "2022" },
  { src: "spirit award.jpg", caption: "Receiving the School Spirit Award", year: "2017" },
];

// Mosaic spans for visual rhythm — varied sizes
const spans = [
  "md:col-span-2 md:row-span-2", // big hero — index 0
  "md:col-span-2",                // wide
  "md:row-span-2",                // tall
  "",
  "md:col-span-2",                // wide
  "",
  "",
  "md:row-span-2",                // tall
  "md:col-span-2",                // wide
  "",
  "",
  "",
  "md:col-span-2",
  "",
];
---

<BaseLayout
  title="Gallery — Todor Aleksandrov"
  description="A small photo gallery — Adare Manor cellars, the Carriage House, UL campus, sommelier exams in Madrid, and a few personal frames."
>
  <Container size="wide" class="py-(--spacing-section)">
    <SectionHeader
      eyebrow="Gallery"
      title="A few frames"
      subtitle={`${photos.length} photos — the cellar, the campus, sommelier exams, a few personal frames. Tap any photo to open.`}
      level={1}
      rule
    />

    <!-- MASONRY GRID -->
    <div
      id="gallery-grid"
      class="mt-12 grid grid-cols-2 md:grid-cols-4 auto-rows-[10rem] md:auto-rows-[14rem] gap-3 md:gap-4"
    >
      {photos.map((p, i) => (
        <button
          type="button"
          class:list={[
            "group/photo relative overflow-hidden rounded-2xl",
            spans[i] ?? "",
          ]}
          style="border:1px solid color-mix(in oklab, var(--text) 8%, transparent)"
          data-photo-index={i}
          aria-label={`Open: ${p.caption}`}
        >
          <Picture
            src={p.src}
            alt={p.caption}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover/photo:scale-105"
          />
          <figcaption
            class="absolute inset-x-0 bottom-0 p-3 text-xs translate-y-2 opacity-0 group-hover/photo:opacity-100 group-hover/photo:translate-y-0 group-focus-visible/photo:opacity-100 transition-all duration-300"
            style="background:linear-gradient(to top, rgba(26,22,20,0.9), transparent); color: var(--color-cream);"
          >
            <span class="block text-[0.7rem] opacity-75 uppercase tracking-[0.16em]">{p.year}</span>
            <span class="block leading-tight mt-0.5">{p.caption}</span>
          </figcaption>
        </button>
      ))}
    </div>
  </Container>

  <!-- LIGHTBOX -->
  <dialog
    id="lightbox"
    class="m-0 p-0 max-w-none w-full h-full bg-transparent backdrop:bg-black/85 backdrop:backdrop-blur-sm"
    aria-label="Photo viewer"
  >
    <div class="relative w-full h-full flex flex-col" style="color: var(--color-cream);">
      <header class="absolute top-0 inset-x-0 z-10 p-4 md:p-6 flex items-center justify-between">
        <p
          id="lightbox-meta"
          class="text-sm font-mono"
          style="color: color-mix(in oklab, var(--color-cream) 75%, transparent)"
        >
          1 / {photos.length}
        </p>
        <button
          id="lightbox-close"
          type="button"
          aria-label="Close gallery"
          class="inline-flex items-center justify-center w-11 h-11 rounded-full text-2xl transition-colors hover:bg-white/15"
          style="color: var(--color-cream); background: rgba(255,255,255,0.08);"
        >×</button>
      </header>

      <div class="flex-1 flex items-center justify-center p-4 md:p-12 relative">
        <button
          id="lightbox-prev"
          type="button"
          aria-label="Previous photo"
          class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-10 inline-flex items-center justify-center w-12 h-12 rounded-full text-2xl transition-colors hover:bg-white/15"
          style="background: rgba(255,255,255,0.08); color: var(--color-cream);"
        >←</button>

        <figure class="max-w-full max-h-full flex flex-col items-center gap-4">
          <img
            id="lightbox-img"
            src=""
            alt=""
            class="max-w-[92vw] max-h-[78vh] rounded-xl object-contain"
          />
          <figcaption id="lightbox-caption" class="text-center text-sm md:text-base max-w-2xl px-4" style="color: var(--color-cream);"></figcaption>
        </figure>

        <button
          id="lightbox-next"
          type="button"
          aria-label="Next photo"
          class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-10 inline-flex items-center justify-center w-12 h-12 rounded-full text-2xl transition-colors hover:bg-white/15"
          style="background: rgba(255,255,255,0.08); color: var(--color-cream);"
        >→</button>
      </div>
    </div>
  </dialog>

  <script is:inline define:vars={{ photos }}>
    (function () {
      const dialog = document.getElementById("lightbox");
      const img = document.getElementById("lightbox-img");
      const caption = document.getElementById("lightbox-caption");
      const meta = document.getElementById("lightbox-meta");
      const triggers = document.querySelectorAll("#gallery-grid [data-photo-index]");
      if (!dialog) return;

      let current = 0;

      function render(index) {
        const p = photos[index];
        if (!p) return;
        current = index;
        if (img) {
          img.src = `/assets/${p.src}`;
          img.alt = p.caption;
        }
        if (caption) caption.textContent = `${p.year} · ${p.caption}`;
        if (meta) meta.textContent = `${index + 1} / ${photos.length}`;
      }

      function open(index) {
        render(index);
        if (!dialog.open) dialog.showModal();
        document.body.style.overflow = "hidden";
      }

      function close() {
        if (dialog.open) dialog.close();
        document.body.style.overflow = "";
      }

      function nav(delta) {
        const next = (current + delta + photos.length) % photos.length;
        render(next);
      }

      triggers.forEach((btn) => {
        btn.addEventListener("click", () => {
          const i = Number(btn.dataset.photoIndex);
          open(i);
        });
      });

      document.getElementById("lightbox-close")?.addEventListener("click", close);
      document.getElementById("lightbox-prev")?.addEventListener("click", () => nav(-1));
      document.getElementById("lightbox-next")?.addEventListener("click", () => nav(1));

      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) close(); // click on backdrop
      });

      dialog.addEventListener("close", () => {
        document.body.style.overflow = "";
      });

      document.addEventListener("keydown", (e) => {
        if (!dialog.open) return;
        if (e.key === "ArrowLeft") nav(-1);
        else if (e.key === "ArrowRight") nav(1);
      });
    })();
  </script>
</BaseLayout>
