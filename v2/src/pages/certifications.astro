---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import Tag from "../components/Tag.astro";
import { formatMonthYear } from "../lib/dates";

const certifications = await getCollection("certifications");

const groupOrder = ["hospitality", "tech", "language", "safety", "other"] as const;
type Cat = (typeof groupOrder)[number];

const groupLabels: Record<Cat, string> = {
  hospitality: "Hospitality & Wine",
  tech: "Tech",
  language: "Language",
  safety: "Safety & First Aid",
  other: "Professional",
};

const groupSubtitles: Record<Cat, string> = {
  hospitality: "Wine education and certified sommelier credentials.",
  tech: "Platform and tooling certifications from work.",
  language: "Verified English proficiency at the highest CEFR level.",
  safety: "Lifeguarding, CPR, AED and first-aid qualifications — kept current.",
  other: "Professional development and regulatory training.",
};

const grouped: Record<Cat, typeof certifications> = {
  hospitality: [],
  tech: [],
  language: [],
  safety: [],
  other: [],
};

for (const cert of certifications) {
  grouped[cert.data.category as Cat].push(cert);
}

// Sort each group by date issued (newest first)
for (const key of groupOrder) {
  grouped[key].sort((a, b) => b.data.issued.localeCompare(a.data.issued));
}

const counts = groupOrder.map((key) => ({
  key,
  label: groupLabels[key],
  count: grouped[key].length,
}));
---

<BaseLayout
  title="Certifications — Todor Aleksandrov"
  description="Seventeen certifications across wine, software, language, safety and professional development."
>
  <Container size="wide" class="py-(--spacing-section)">
    <SectionHeader
      eyebrow="Credentials"
      title="Certifications"
      subtitle={`${certifications.length} certifications across five disciplines — wine education, language proficiency, lifeguarding and first aid, platform tooling, and professional training.`}
      level={1}
      rule
    />

    <!-- Quick anchors -->
    <nav
      aria-label="Categories"
      class="mt-10 flex flex-wrap gap-2"
    >
      {counts.map((c) => c.count > 0 && (
        <a
          href={`#cat-${c.key}`}
          class="px-3.5 py-1.5 rounded-full text-xs font-medium tracking-wide uppercase border transition-colors hover:border-burgundy-600 hover:text-burgundy-600"
          style="border-color: color-mix(in oklab, var(--text) 15%, transparent); color: var(--text-soft);"
        >
          {c.label} <span class="opacity-60 font-mono ml-1">{c.count}</span>
        </a>
      ))}
    </nav>

    <!-- Groups -->
    <div class="mt-16 space-y-16 md:space-y-20">
      {groupOrder.map((key) => grouped[key].length > 0 && (
        <section id={`cat-${key}`}>
          <header class="mb-8 max-w-3xl">
            <p class="eyebrow">{key}</p>
            <h2
              class="font-display tracking-[-0.02em] mt-2"
              style="font-size: clamp(1.875rem, 4vw, 2.75rem); line-height: 1.1;"
            >
              {groupLabels[key]}
            </h2>
            <p class="mt-3 text-base" style="color:var(--text-soft)">
              {groupSubtitles[key]}
            </p>
          </header>

          <div class="grid gap-4 md:grid-cols-2">
            {grouped[key].map((cert) => (
              <Card variant="surface" padding="md" class="flex gap-4 items-start">
                {cert.data.icon && (
                  <img
                    src={`/assets/${cert.data.icon}`}
                    alt={cert.data.issuer}
                    class="w-14 h-14 rounded-xl object-contain bg-cream p-1.5 shrink-0"
                    loading="lazy"
                  />
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2 flex-wrap">
                    <h3 class="font-display text-xl tracking-[-0.01em] leading-tight">
                      {cert.data.title}
                    </h3>
                  </div>
                  <p class="text-sm mt-1" style="color:var(--text-soft)">
                    {cert.data.issuer}
                  </p>
                  <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mt-3 text-xs" style="color:var(--text-soft)">
                    <span>Issued {formatMonthYear(cert.data.issued)}</span>
                    {cert.data.expires && (
                      <>
                        <span aria-hidden="true">·</span>
                        <span>Expires {formatMonthYear(cert.data.expires)}</span>
                      </>
                    )}
                  </div>
                  {cert.data.credentialId && (
                    <p
                      class="mt-2 text-[0.7rem] font-mono"
                      style="color:var(--text-soft)"
                    >
                      ID: {cert.data.credentialId}
                    </p>
                  )}
                  {cert.data.issuerUrl && (
                    <a
                      href={cert.data.issuerUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 mt-3 text-xs font-medium"
                      style="color:var(--accent)"
                    >
                      Issuer site <span aria-hidden="true">↗</span>
                    </a>
                  )}
                </div>
              </Card>
            ))}
          </div>
        </section>
      ))}
    </div>
  </Container>
</BaseLayout>
