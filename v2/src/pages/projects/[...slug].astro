---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import Button from "../../components/Button.astro";
import Tag from "../../components/Tag.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: index > 0 ? sorted[index - 1] : sorted[sorted.length - 1],
      next: index < sorted.length - 1 ? sorted[index + 1] : sorted[0],
    },
  }));
}

const { project, prev, next } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const sections = [
  data.problem && { num: "01", label: "The problem", body: data.problem },
  data.approach && { num: "02", label: "The approach", body: data.approach },
  data.contribution && { num: "03", label: "My contribution", body: data.contribution },
  data.learnings && { num: "04", label: "What I learned", body: data.learnings },
].filter(Boolean) as { num: string; label: string; body: string }[];
---

<BaseLayout
  title={`${data.title} — Project · Todor Aleksandrov`}
  description={data.description}
>
  <Container size="narrow" class="pt-12 md:pt-16">
    <a
      href="/projects"
      class="inline-flex items-center gap-2 text-sm tracking-wide hover:text-burgundy-600 transition-colors"
      style="color:var(--text-soft)"
    >
      <span aria-hidden="true">←</span> All projects
    </a>

    <!-- HEADER -->
    <header class="mt-10 space-y-5">
      <p class="eyebrow">Case study · {data.tagline}</p>
      <h1
        class="font-display tracking-[-0.03em]"
        style="font-size:clamp(2.75rem, 6vw, 5rem); line-height:1.02;"
      >
        {data.title}
      </h1>
      <p class="text-lg md:text-xl leading-relaxed max-w-2xl" style="color:var(--text-soft)">
        {data.description}
      </p>

      <div class="flex flex-wrap gap-1.5 pt-2">
        {data.stack.map((tech) => <Tag>{tech}</Tag>)}
      </div>

      <div class="flex flex-wrap gap-3 pt-4">
        {data.liveUrl && (
          <Button href={data.liveUrl} target="_blank" arrow>Live demo</Button>
        )}
        {data.githubUrl && (
          <Button href={data.githubUrl} target="_blank" variant="outline">
            View source
          </Button>
        )}
      </div>
    </header>
  </Container>

  <!-- HERO IMAGE -->
  {data.image && (
    <Container size="wide" class="mt-12 md:mt-16">
      <div
        class="aspect-[16/9] rounded-3xl overflow-hidden border"
        style="border-color: color-mix(in oklab, var(--text) 10%, transparent); background: color-mix(in oklab, var(--text) 4%, transparent);"
      >
        <img
          src={`/assets/${data.image}`}
          alt={data.title}
          class="w-full h-full object-cover"
          fetchpriority="high"
        />
      </div>
    </Container>
  )}

  <!-- NUMBERED SECTIONS -->
  <Container size="narrow" class="mt-16 md:mt-24 space-y-12 md:space-y-16">
    {sections.map((sec) => (
      <section class="grid md:grid-cols-[6rem_1fr] gap-4 md:gap-10">
        <p
          class="font-display text-3xl tracking-[-0.02em] tabular-nums"
          style="color:var(--accent)"
        >
          {sec.num}
        </p>
        <div>
          <h2 class="font-display text-2xl md:text-3xl tracking-[-0.01em] mb-3">
            {sec.label}
          </h2>
          <p
            class="text-base md:text-lg leading-relaxed"
            style="color:var(--text-soft)"
          >
            {sec.body}
          </p>
        </div>
      </section>
    ))}
  </Container>

  <!-- MARKDOWN BODY -->
  <Container size="narrow" class="mt-16 md:mt-24">
    <hr class="rule mb-12" />
    <div class="prose-content text-lg leading-relaxed space-y-6" style="color:var(--text-soft)">
      <Content />
    </div>
  </Container>

  <!-- PREV / NEXT NAVIGATION -->
  <Container size="wide" class="mt-24 mb-(--spacing-section)">
    <hr class="rule mb-10" />
    <nav
      aria-label="Project navigation"
      class="grid sm:grid-cols-2 gap-4"
    >
      <a
        href={`/projects/${prev.id}`}
        class="group/nav rounded-2xl p-6 border hover:border-burgundy-600 transition-colors"
        style="border-color: color-mix(in oklab, var(--text) 10%, transparent);"
      >
        <p class="eyebrow mb-2">← Previous</p>
        <p class="font-display text-2xl tracking-[-0.01em] group-hover/nav:text-burgundy-600 transition-colors">
          {prev.data.title}
        </p>
        <p class="text-sm mt-1" style="color:var(--text-soft)">
          {prev.data.tagline}
        </p>
      </a>
      <a
        href={`/projects/${next.id}`}
        class="group/nav rounded-2xl p-6 border text-right hover:border-burgundy-600 transition-colors"
        style="border-color: color-mix(in oklab, var(--text) 10%, transparent);"
      >
        <p class="eyebrow mb-2">Next →</p>
        <p class="font-display text-2xl tracking-[-0.01em] group-hover/nav:text-burgundy-600 transition-colors">
          {next.data.title}
        </p>
        <p class="text-sm mt-1" style="color:var(--text-soft)">
          {next.data.tagline}
        </p>
      </a>
    </nav>
  </Container>
</BaseLayout>

<style is:global>
  .prose-content h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .prose-content h3 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .prose-content p {
    margin-top: 0.75rem;
  }
  .prose-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 200ms ease;
  }
  .prose-content a:hover {
    text-decoration-color: var(--accent);
  }
  .prose-content ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-top: 0.75rem;
  }
  .prose-content code {
    background: color-mix(in oklab, var(--text) 7%, transparent);
    padding: 0.1em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
</style>
