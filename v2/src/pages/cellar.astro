---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Card from "../components/Card.astro";

type Style = "red" | "white" | "rosé" | "orange" | "sweet" | "sparkling" | "spirit";
type Location = "home" | "limerick" | "bulgaria";

interface Bottle {
  name: string;
  producer: string;
  vintage?: string;
  variety: string[];
  region: string;
  style: Style;
  abv?: string;
  note: string;
  awards?: string;
  location: Location;
}

const styleConfig: Record<Style, { label: string; color: string }> = {
  red:       { label: "Red",       color: "#9f1239" },
  white:     { label: "White",     color: "#b45309" },
  rosé:      { label: "Rosé",      color: "#db2777" },
  orange:    { label: "Orange",    color: "#c2410c" },
  sweet:     { label: "Sweet",     color: "#a16207" },
  sparkling: { label: "Sparkling", color: "#0369a1" },
  spirit:    { label: "Spirit",    color: "#78350f" },
};

const locationConfig: Record<Location, string> = {
  home:     "Main collection",
  limerick: "From Bulgaria",
  bulgaria: "Still in Shumen",
};

const bottles: Bottle[] = [

  // ── Home cellar ──────────────────────────────────────────────────────────
  {
    name: "Gran Reserva (Magnum)",
    producer: "Bodegas Riojanas",
    vintage: "2017",
    variety: ["Tempranillo", "Graciano"],
    region: "Rioja, Spain",
    style: "red",
    note: "Rioja Gran Reserva in magnum. Extended oak ageing — the format slows evolution and gives more to look forward to.",
    location: "home",
  },
  {
    name: "Vintage Brut",
    producer: "Veuve Clicquot Ponsardin",
    vintage: "1996",
    variety: ["Pinot Noir", "Chardonnay", "Pinot Meunier"],
    region: "Champagne",
    style: "sparkling",
    note: "Nearly thirty years on the cork. Toasty, oxidative, complex — a benchmark for what aged Champagne becomes.",
    location: "home",
  },
  {
    name: "La Grande Année",
    producer: "Bollinger",
    vintage: "2014",
    variety: ["Pinot Noir", "Chardonnay"],
    region: "Champagne",
    style: "sparkling",
    note: "One of Bollinger's finest recent vintages. Pinot Noir-dominant, structured, built for the long haul.",
    location: "home",
  },
  {
    name: "Vintage Port",
    producer: "Kopke",
    vintage: "1999",
    variety: ["Touriga Nacional", "Touriga Franca", "Tinta Roriz"],
    region: "Douro, Portugal",
    style: "sweet",
    note: "A quarter-century of bottle age. Douro at its richest — dark fruit giving way to dried fig and walnut.",
    location: "home",
  },
  {
    name: "21 Year Old Single Malt",
    producer: "Bushmills",
    variety: ["Single Malt Irish Whiskey"],
    region: "County Antrim, Ireland",
    style: "spirit",
    abv: "40%",
    note: "Triple-distilled, finished in Oloroso, Bourbon and Madeira casks. The longest-aged standard expression in the range.",
    location: "home",
  },
  {
    name: "Very Rare 200th Anniversary 28 Year Old",
    producer: "Midleton",
    variety: ["Single Pot Still Irish Whiskey"],
    region: "County Cork, Ireland",
    style: "spirit",
    note: "Special edition celebrating Midleton Distillery's bicentenary (est. 1825). 28 years old — one of the most significant Irish whiskey releases in memory.",
    location: "home",
  },
  {
    name: "Eiswein",
    producer: "Zantho",
    vintage: "2020",
    variety: ["Welschriesling"],
    region: "Burgenland, Austria",
    style: "sweet",
    note: "Grapes harvested frozen at natural temperatures, producing intensely concentrated sweetness with firm acidity to balance.",
    location: "home",
  },
  {
    name: "Rosé Brut NV",
    producer: "Taittinger",
    variety: ["Chardonnay", "Pinot Noir"],
    region: "Champagne",
    style: "sparkling",
    note: "Pale salmon, delicate red fruit. Chardonnay-dominant with a proportion of still Pinot Noir — lighter and more elegant than most Champagne rosés.",
    location: "home",
  },
  {
    name: "Demi-Sec NV",
    producer: "Taittinger",
    variety: ["Chardonnay", "Pinot Noir"],
    region: "Champagne",
    style: "sparkling",
    note: "Off-dry with noticeable dosage. Far better with a fruit tart or soft cheese than a dry Brut — the underrated style.",
    location: "home",
  },
  {
    name: "Etichetta Nera",
    producer: "Vecchia Romagna",
    variety: ["Italian Brandy"],
    region: "Emilia-Romagna, Italy",
    style: "spirit",
    note: "Italy's most iconic brandy, aged in Slovenian oak. The Black Label — richer and more structured than the standard range, thoroughly underrated outside Italy.",
    location: "home",
  },
  {
    name: "Laieta Rosé Gran Reserva Brut Nature",
    producer: "Alta Alella",
    variety: ["Pansa Rosada"],
    region: "DO Alella, Catalonia",
    style: "sparkling",
    note: "Made from a rare local pink-skinned grape with extended lees ageing and zero dosage. Bone dry, complex, completely under the radar.",
    location: "home",
  },

  // ── Brought from Bulgaria ────────────────────────────────────────────────
  {
    name: "Troyanska Slivova Special Reserva",
    producer: "Vinprom Troyan",
    vintage: "25-year-old",
    variety: ["Plum Distillate"],
    region: "Troyan, Bulgaria",
    style: "spirit",
    abv: "40%",
    note: "Twenty-five years in 500 L oak. Caramelised plum, dried stone fruit, integrated warmth — closer to Cognac territory than any slivovitz has a right to be.",
    location: "limerick",
  },
  {
    name: "Mavrud Reserva",
    producer: "Edoardo Miroglio",
    vintage: "2022",
    variety: ["Mavrud"],
    region: "PDO Nova Zagora · Thracian Valley",
    style: "red",
    abv: "14.5%",
    note: "24 months in 500 L Bulgarian oak. Ripe cherry, dry leaves, mushroom, walnut. Supple tannins, long smoky finish — clay-slate estate soils above Elenovo.",
    location: "limerick",
  },

  // ── Still in Bulgaria ────────────────────────────────────────────────────
  {
    name: "DOGMA Mavrud Barrel Aged",
    producer: "Zaara Estate",
    variety: ["Mavrud"],
    region: "Sakar · Thracian Valley",
    style: "red",
    note: "Boutique Sakar estate, Italian oenologist Giovanni Colugnati. Dense and harmonious — blackberry, mulberry, powerful Mavrud tannins with an earthy, savoury edge.",
    location: "bulgaria",
  },
  {
    name: "DOGMA Misket",
    producer: "Zaara Estate",
    variety: ["Misket"],
    region: "Sakar · Thracian Valley",
    style: "white",
    note: "Aromatic white from the Sakar foothills. White flowers, green apple, citrus zest, a delicate muscat note — built on freshness.",
    location: "bulgaria",
  },
  {
    name: "Cabernet Sauvignon Special Reserva",
    producer: "Vinex Slavyantsi",
    vintage: "2007",
    variety: ["Cabernet Sauvignon"],
    region: "Thracian Valley",
    style: "red",
    note: "Almost two decades of age. Tertiary territory: leather, tobacco, dried herbs, mellow tannins. A Thracian Cabernet in full autumn — a time capsule.",
    location: "bulgaria",
  },
  {
    name: "Shiroka Melnishka Loza Rosé",
    producer: "Museum of Wine, Melnik",
    vintage: "2024",
    variety: ["Shiroka Melnishka Loza"],
    region: "Melnik · Struma Valley",
    style: "rosé",
    note: "Filled and wax-sealed on-site at Melnik's cave-cellar wine museum. From one of the world's rarest indigenous varieties — grown only in a small zone around Melnik.",
    location: "bulgaria",
  },
  {
    name: "Grande Cuvée",
    producer: "Bessa Valley",
    vintage: "2020",
    variety: ["Cabernet Sauvignon", "Merlot", "Syrah", "Petit Verdot"],
    region: "Thracian Valley",
    style: "red",
    note: "18 months in 100% new French oak. Blue plum, blackberry, cacao, velvety tannins. One of Bulgaria's most serious reds — built for the cellar.",
    awards: "DiVino Top 50 Bulgaria 2024",
    location: "bulgaria",
  },
  {
    name: "Enira Reserva",
    producer: "Bessa Valley",
    vintage: "2018",
    variety: ["Merlot", "Syrah", "Petit Verdot", "Cabernet Sauvignon"],
    region: "Thracian Valley",
    style: "red",
    note: "18 months French oak, 30% new. Plum, black cherry, violet, chocolate. Round and full with harmonious tannins — honoured at the 2023 London Wine Competition.",
    location: "bulgaria",
  },
  {
    name: "Gold Label Aszú 6 Puttonyos",
    producer: "Royal Tokaji",
    vintage: "2017",
    variety: ["Furmint"],
    region: "Tokaj · Hungary",
    style: "sweet",
    abv: "10.5%",
    note: "96 pts Wine Enthusiast. Dried apricot, honey, orange peel — vibrant acidity lifts the sweetness perfectly. A benchmark 6 Puttonyos.",
    awards: "96 pts Wine Enthusiast",
    location: "bulgaria",
  },
  {
    name: "Sweet Wine Barrel Aged",
    producer: "Villa Melnik",
    variety: ["Melnik 55"],
    region: "Struma River Valley",
    style: "sweet",
    note: "Late-harvest grapes dried on racks post-harvest, then barrel-aged. 80 g/L RS, no added sugar. Caramelised nuts, fig jam, dark chocolate, coffee.",
    location: "bulgaria",
  },
  {
    name: "AplauZ Melnik 55 Premium Reserve",
    producer: "Villa Melnik",
    variety: ["Melnik 55"],
    region: "PDO Melnik · Struma River Valley",
    style: "red",
    abv: "14.5%",
    note: "18 months in Bulgarian oak. Dark plum, dried fruit, white pepper, spice, sandalwood — a refined expression of the Melnik terroir.",
    awards: "Gold, Balkan IWC 2021",
    location: "bulgaria",
  },
  {
    name: "Orange Wine",
    producer: "Villa Melnik",
    variety: ["Viognier", "Keratsuda"],
    region: "Struma River Valley",
    style: "orange",
    note: "Two weeks on skins. Keratsuda — an ultra-rare indigenous variety grown only in Villa Melnik's estate. Quince, pear, white cherry, tropical fruit, textured skin-contact grip.",
    location: "bulgaria",
  },
  {
    name: "Rare Varieties — Shiroka Melnik Bush Vine",
    producer: "Villa Melnik",
    variety: ["Shiroka Melnishka Loza"],
    region: "Struma River Valley",
    style: "red",
    abv: "14%",
    note: "Single 0.1 ha plot, goblet-trained vines. The mother variety of Melnik 55, Melnik 1300, Ruen and Sandanski Misket. ~1,400 bottles per vintage. Tobacco, dried herbs, cherry.",
    location: "bulgaria",
  },
  {
    name: "Rare Varieties — Melnik 1300 Jubilee",
    producer: "Villa Melnik",
    variety: ["Melnik 1300"],
    region: "Struma River Valley",
    style: "red",
    abv: "14.5%",
    note: "Shiroka Melnishka Loza × Saperavi cross. Profoundly inky — blackberry, licorice, mocha, pomegranate freshness. 12 months in new Bulgarian oak.",
    awards: "Gold, Balkans IWF 2024",
    location: "bulgaria",
  },
];

const uniqueProducers = new Set(bottles.map((b) => b.producer)).size;
const bulgariaCount   = bottles.filter((b) => b.location === "bulgaria").length;
const vintageYears    = bottles.flatMap((b) =>
  b.vintage && /^\d{4}$/.test(b.vintage) ? [parseInt(b.vintage)] : []
);
const oldestYear      = vintageYears.length ? Math.min(...vintageYears) : null;

// Pre-compute per-bottle display data so the template stays type-cast-free
const bottlesWithMeta = bottles.map((b, i) => ({
  ...b,
  styleLabel:    styleConfig[b.style].label,
  styleColor:    styleConfig[b.style].color,
  locationLabel: locationConfig[b.location],
  vintageSort:   b.vintage && /^\d{4}$/.test(b.vintage) ? b.vintage : "0",
  idx:           i,
}));

// Flat arrays for filter buttons — Object.entries preserves insertion order
const styleEntries    = Object.entries(styleConfig);
const locationEntries = Object.entries(locationConfig);
---

<BaseLayout
  title="The Cellar — Todor Aleksandrov"
  description={`A personal cellar inventory — ${bottles.length} bottles across ${uniqueProducers} producers. Champagne, Port, Bulgarian indigenous varieties, and a few Irish whiskies that had no business being bought on a student budget.`}
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10"
      style="background:
        radial-gradient(60% 50% at 80% 20%, color-mix(in oklab, var(--color-burgundy-600) 10%, transparent), transparent 70%),
        radial-gradient(50% 40% at 10% 80%, color-mix(in oklab, var(--color-burgundy-300) 6%, transparent), transparent 70%);"
    ></div>

    <Container size="wide" class="pt-(--spacing-section) pb-16">
      <p class="eyebrow">The cellar</p>
      <h1
        class="font-display tracking-[-0.03em] mt-4"
        style="font-size:clamp(3rem, 8vw, 6.5rem); line-height:0.98;"
      >
        Bottles worth
        <em
          class="not-italic block mt-2"
          style="font-style: italic; color: var(--accent);"
        >
          remembering.
        </em>
      </h1>
      <p
        class="mt-7 text-lg md:text-xl leading-relaxed max-w-2xl"
        style="color:var(--text-soft)"
      >
        A personal inventory — wines and spirits collected, gifted, and brought back from travels.
        Mostly Bulgarian indigenous varieties; some very old Champagne; the odd Irish whiskey that had no business being bought on a student budget.
      </p>

      <dl
        class="mt-10 flex flex-wrap gap-x-12 gap-y-5 border-t pt-8"
        style="border-color: color-mix(in oklab, var(--text) 10%, transparent);"
      >
        <div>
          <dt class="text-xs tracking-[0.16em] uppercase" style="color: var(--text-soft)">Bottles</dt>
          <dd class="font-display text-4xl tracking-[-0.02em] mt-1" style="color: var(--accent)">{bottles.length}</dd>
        </div>
        <div>
          <dt class="text-xs tracking-[0.16em] uppercase" style="color: var(--text-soft)">Producers</dt>
          <dd class="font-display text-4xl tracking-[-0.02em] mt-1" style="color: var(--accent)">{uniqueProducers}</dd>
        </div>
        <div>
          <dt class="text-xs tracking-[0.16em] uppercase" style="color: var(--text-soft)">Still in Bulgaria</dt>
          <dd class="font-display text-4xl tracking-[-0.02em] mt-1" style="color: var(--accent)">{bulgariaCount}</dd>
        </div>
        {oldestYear && (
          <div>
            <dt class="text-xs tracking-[0.16em] uppercase" style="color: var(--text-soft)">Oldest vintage</dt>
            <dd class="font-display text-4xl tracking-[-0.02em] mt-1" style="color: var(--accent)">{oldestYear}</dd>
          </div>
        )}
      </dl>
    </Container>
  </section>

  <!-- CONTROLS -->
  <div
    class="sticky z-30 border-b py-4 backdrop-blur-md"
    style="top: 65px; background: color-mix(in oklab, var(--bg) 85%, transparent); border-color: color-mix(in oklab, var(--text) 8%, transparent);"
  >
    <Container size="wide">
      <!-- Search + sort row -->
      <div class="flex gap-3 items-center">
        <div class="relative flex-1">
          <svg
            class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none"
            style="color: var(--text-soft)"
            fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24" aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="cellar-search"
            type="search"
            placeholder="Search name, producer, grape, region…"
            class="w-full pl-9 pr-4 py-2 rounded-xl text-sm border outline-none transition-colors"
            style="background: color-mix(in oklab, var(--surface) 80%, transparent); border-color: color-mix(in oklab, var(--text) 12%, transparent); color: var(--text);"
          />
        </div>
        <select
          id="cellar-sort"
          class="text-sm rounded-xl px-3 py-2 border outline-none cursor-pointer"
          style="background: color-mix(in oklab, var(--surface) 80%, transparent); border-color: color-mix(in oklab, var(--text) 12%, transparent); color: var(--text);"
          aria-label="Sort bottles"
        >
          <option value="default">Default order</option>
          <option value="name-asc">Name A → Z</option>
          <option value="name-desc">Name Z → A</option>
          <option value="vintage-asc">Vintage — oldest first</option>
          <option value="vintage-desc">Vintage — newest first</option>
        </select>
      </div>

      <!-- Style + location filter row -->
      <div class="mt-3 flex flex-wrap gap-2 items-center">
        <!-- Style filters -->
        <div class="flex flex-wrap gap-1.5" role="group" aria-label="Filter by style">
          <button
            class="cellar-style-btn px-3 py-1 rounded-full text-xs font-medium border transition-colors"
            data-style=""
            aria-pressed="true"
            style="border-color: color-mix(in oklab, var(--text) 18%, transparent); color: var(--text);"
          >
            All styles
          </button>
          {styleEntries.map(([key, cfg]) => (
            <button
              class="cellar-style-btn inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border transition-colors"
              data-style={key}
              aria-pressed="false"
              style={`border-color: ${cfg.color}22; color: ${cfg.color};`}
            >
              <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background:${cfg.color};`}></span>
              {cfg.label}
            </button>
          ))}
        </div>

        <span class="hidden sm:block w-px h-4 mx-1" style="background: color-mix(in oklab, var(--text) 15%, transparent);"></span>

        <!-- Location filters -->
        <div class="flex flex-wrap gap-1.5" role="group" aria-label="Filter by location">
          <button
            class="cellar-loc-btn px-3 py-1 rounded-full text-xs font-medium border transition-colors"
            data-location=""
            aria-pressed="true"
            style="border-color: color-mix(in oklab, var(--text) 18%, transparent); color: var(--text);"
          >
            All locations
          </button>
          {locationEntries.map(([key, label]) => (
            <button
              class="cellar-loc-btn px-3 py-1 rounded-full text-xs font-medium border transition-colors"
              data-location={key}
              aria-pressed="false"
              style="border-color: color-mix(in oklab, var(--text) 12%, transparent); color: var(--text-soft);"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Result count -->
      <p
        id="cellar-count"
        class="mt-2.5 text-xs font-mono"
        style="color: var(--text-soft)"
      >
        {bottles.length} bottles
      </p>
    </Container>
  </div>

  <!-- GRID -->
  <Container size="wide" class="py-(--spacing-section)">
    <div id="cellar-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {bottlesWithMeta.map((bottle) => (
        <article
          data-index={bottle.idx}
          data-name={bottle.name.toLowerCase()}
          data-producer={bottle.producer.toLowerCase()}
          data-region={bottle.region.toLowerCase()}
          data-variety={bottle.variety.join(" ").toLowerCase()}
          data-style={bottle.style}
          data-location={bottle.location}
          data-vintage={bottle.vintageSort}
        >
          <Card variant="outline" padding="md" class="h-full flex flex-col gap-4">
            <!-- Header row: style dot + name + vintage -->
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class="inline-flex items-center gap-1.5 text-[0.65rem] font-semibold uppercase tracking-[0.14em]"
                    style={`color: ${bottle.styleColor};`}
                  >
                    <span
                      class="inline-block w-1.5 h-1.5 rounded-full flex-shrink-0"
                      style={`background: ${bottle.styleColor};`}
                    ></span>
                    {bottle.styleLabel}
                  </span>
                  <span
                    class="text-[0.6rem] px-1.5 py-0.5 rounded tracking-[0.08em]"
                    style="background: color-mix(in oklab, var(--text) 7%, transparent); color: var(--text-soft);"
                  >
                    {bottle.locationLabel}
                  </span>
                </div>
                <h3 class="font-display text-[1.05rem] tracking-[-0.01em] leading-tight mt-2">
                  {bottle.name}
                </h3>
              </div>
              {bottle.vintage && /^\d{4}$/.test(bottle.vintage) && (
                <span class="font-mono text-sm flex-shrink-0 pt-0.5" style="color: var(--text-soft)">
                  {bottle.vintage}
                </span>
              )}
              {bottle.vintage && !/^\d{4}$/.test(bottle.vintage) && (
                <span class="font-mono text-xs flex-shrink-0 pt-1 text-right" style="color: var(--text-soft)">
                  {bottle.vintage}
                </span>
              )}
            </div>

            <!-- Producer + region + ABV -->
            <div>
              <p class="text-sm font-medium">{bottle.producer}</p>
              <p class="text-xs mt-0.5" style="color: var(--text-soft)">{bottle.region}</p>
              {bottle.abv && (
                <p class="text-[0.7rem] font-mono mt-1" style="color: var(--text-soft)">{bottle.abv} ABV</p>
              )}
            </div>

            <!-- Variety pills -->
            <div class="flex flex-wrap gap-1.5">
              {bottle.variety.map((v) => (
                <span
                  class="text-[0.65rem] px-2 py-0.5 rounded-full border"
                  style="border-color: color-mix(in oklab, var(--text) 12%, transparent); color: var(--text-soft);"
                >
                  {v}
                </span>
              ))}
            </div>

            <!-- Tasting note -->
            <p class="text-sm leading-relaxed flex-1" style="color: var(--text-soft)">
              {bottle.note}
            </p>

            <!-- Awards -->
            {bottle.awards && (
              <p class="text-[0.65rem] font-mono uppercase tracking-[0.1em]" style="color: var(--accent)">
                ★ {bottle.awards}
              </p>
            )}
          </Card>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="cellar-empty" hidden class="py-24 text-center">
      <p class="font-display text-2xl tracking-[-0.01em]" style="color: var(--text-soft)">No bottles match.</p>
      <p class="mt-2 text-sm" style="color: var(--text-soft)">Try a different search or clear the filters.</p>
      <button
        id="cellar-reset"
        class="mt-6 px-4 py-2 text-sm rounded-full border transition-colors hover:border-burgundy-600 hover:text-burgundy-600"
        style="border-color: color-mix(in oklab, var(--text) 18%, transparent); color: var(--text-soft);"
      >
        Clear all filters
      </button>
    </div>
  </Container>

  <!-- PULL QUOTE -->
  <Container size="narrow" class="pb-(--spacing-section)">
    <blockquote class="relative">
      <span
        aria-hidden="true"
        class="absolute -top-12 -left-4 font-display select-none"
        style="font-size:8rem; line-height:1; color: color-mix(in oklab, var(--accent) 25%, transparent);"
      >"</span>
      <p
        class="font-display tracking-[-0.02em] relative"
        style="font-size:clamp(1.75rem, 4vw, 2.75rem); line-height:1.15;"
      >
        A cellar is not a collection. It's a set of promises you made to yourself about who you'll be drinking with, and when.
      </p>
      <footer class="mt-6 text-sm" style="color:var(--text-soft)">
        — A working note.
      </footer>
    </blockquote>
  </Container>
</BaseLayout>

<script is:inline>
(function () {
  const grid       = document.getElementById("cellar-grid");
  const searchEl   = document.getElementById("cellar-search");
  const sortEl     = document.getElementById("cellar-sort");
  const countEl    = document.getElementById("cellar-count");
  const emptyEl    = document.getElementById("cellar-empty");
  const resetBtn   = document.getElementById("cellar-reset");
  const styleBtns  = document.querySelectorAll(".cellar-style-btn");
  const locBtns    = document.querySelectorAll(".cellar-loc-btn");

  if (!grid || !searchEl || !sortEl) return;

  // Cache original DOM order
  const allCards = Array.from(grid.querySelectorAll("article"));
  allCards.forEach((c, i) => (c.dataset.index = String(i)));

  let activeStyle = "";
  let activeLoc   = "";

  function applyActiveStyle(btn, group) {
    group.forEach((b) => {
      const isActive = b === btn;
      b.setAttribute("aria-pressed", isActive ? "true" : "false");
      b.style.fontWeight = isActive ? "600" : "";
      b.style.boxShadow  = isActive
        ? "inset 0 0 0 1.5px currentColor"
        : "";
    });
  }

  function update() {
    const q    = searchEl.value.toLowerCase().trim();
    const sort = sortEl.value;

    // Filter
    const visible = allCards.filter((c) => {
      const ds = c.dataset;
      const styleOk = !activeStyle || ds.style === activeStyle;
      const locOk   = !activeLoc   || ds.location === activeLoc;
      const searchOk =
        !q ||
        ds.name.includes(q)     ||
        ds.producer.includes(q) ||
        ds.region.includes(q)   ||
        ds.variety.includes(q);
      return styleOk && locOk && searchOk;
    });

    // Sort
    const sorted = [...visible].sort((a, b) => {
      if (sort === "name-asc")
        return a.dataset.name.localeCompare(b.dataset.name);
      if (sort === "name-desc")
        return b.dataset.name.localeCompare(a.dataset.name);
      if (sort === "vintage-asc") {
        const av = parseInt(a.dataset.vintage) || 9999;
        const bv = parseInt(b.dataset.vintage) || 9999;
        return av - bv;
      }
      if (sort === "vintage-desc") {
        const av = parseInt(a.dataset.vintage) || 0;
        const bv = parseInt(b.dataset.vintage) || 0;
        return bv - av;
      }
      // default: original order
      return parseInt(a.dataset.index) - parseInt(b.dataset.index);
    });

    // Hide all, then show sorted
    allCards.forEach((c) => (c.hidden = true));
    sorted.forEach((c) => {
      c.hidden = false;
      grid.appendChild(c);
    });

    // Count + empty state
    const total = allCards.length;
    countEl.textContent =
      sorted.length === total
        ? `${total} bottle${total !== 1 ? "s" : ""}`
        : `${sorted.length} of ${total} bottle${total !== 1 ? "s" : ""}`;
    emptyEl.hidden = sorted.length > 0;
  }

  // Style filter buttons
  styleBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeStyle = btn.dataset.style || "";
      applyActiveStyle(btn, Array.from(styleBtns));
      update();
    });
  });

  // Location filter buttons
  locBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeLoc = btn.dataset.location || "";
      applyActiveStyle(btn, Array.from(locBtns));
      update();
    });
  });

  // Search and sort
  searchEl.addEventListener("input", update);
  sortEl.addEventListener("change", update);

  // Reset button
  if (resetBtn) {
    resetBtn.addEventListener("click", () => {
      searchEl.value = "";
      sortEl.value   = "default";
      activeStyle    = "";
      activeLoc      = "";
      applyActiveStyle(styleBtns[0], Array.from(styleBtns));
      applyActiveStyle(locBtns[0],   Array.from(locBtns));
      update();
    });
  }

  // Initial render
  update();
})();
</script>
