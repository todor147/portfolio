---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import Tag from "../components/Tag.astro";
import Button from "../components/Button.astro";
import Picture from "../components/Picture.astro";
import { byMostRecent, formatRange, formatMonthYear } from "../lib/dates";

const experience = await getCollection("experience");
const certifications = await getCollection("certifications");
const education = await getCollection("education");

function earliestStartIn(category: string): string | undefined {
  return experience
    .filter((e) => e.data.category === category)
    .map((e) => e.data.start)
    .sort()[0];
}

function yearsSince(yyyymm: string | undefined): number {
  if (!yyyymm) return 0;
  const [y, m] = yyyymm.split("-");
  const start = new Date(Number(y), Number(m) - 1, 1);
  const months =
    (new Date().getFullYear() - start.getFullYear()) * 12 +
    (new Date().getMonth() - start.getMonth());
  return Math.round((months / 12) * 10) / 10;
}

const sommelierRole = experience.find(
  (e) => e.data.title === "Junior Sommelier" && e.data.current,
);
const latestCert = [...certifications].sort((a, b) =>
  b.data.issued.localeCompare(a.data.issued),
)[0];
const ulBSc = education.find(
  (e) => e.data.status === "current" && e.data.degree.includes("Bachelor"),
);
const ulMSc = education.find(
  (e) => e.data.status === "upcoming" && e.data.degree.includes("Master"),
);
const educationJourney = [...education].sort((a, b) => a.data.order - b.data.order);

const hospitalityYears = yearsSince(earliestStartIn("hospitality"));
const softwareYears = yearsSince(earliestStartIn("software"));

const funFacts = [
  "Builds PCs for fun",
  "Swim Ireland qualified swim teacher",
  "Beach + pool lifeguard certified",
  "Sommelier in training — CMS Intro · WSET L2 Merit",
  "Bilingual Bulgarian / English interpreter",
];

const currentSoftwareRole = experience
  .filter((e) => e.data.category === "software" && e.data.current)
  .sort((a, b) => byMostRecent(a.data, b.data))[0];
---

<BaseLayout
  title="About — Todor Aleksandrov"
  description="The CS-meets-sommelier path: who I am, where I'm working, what I'm learning, and the small things that make the picture whole."
>
  <Container size="wide" class="py-(--spacing-section) space-y-16">
    <SectionHeader
      eyebrow="About"
      title="A computer science student in a sommelier's apron"
      subtitle="Two worlds that look unrelated on paper turn out to demand the same thing: precision, taste, and noticing what others miss."
      level={1}
      rule
    />

    <!-- BENTO GRID -->
    <div class="grid gap-4 md:gap-5 md:grid-cols-6 auto-rows-[minmax(0,auto)]">
      <!-- PORTRAIT (large, top-left, spans 4 cols × 2 rows) -->
      <div
        class="md:col-span-4 md:row-span-2 relative rounded-3xl overflow-hidden min-h-[28rem] md:min-h-0"
        style="border:1px solid color-mix(in oklab, var(--text) 10%, transparent)"
      >
        <Picture
          src="about.jpg"
          alt="Todor Aleksandrov"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div
          class="absolute inset-0 flex flex-col justify-end p-6 md:p-8"
          style="background:linear-gradient(to top, rgba(26,22,20,0.85) 0%, rgba(26,22,20,0.35) 35%, transparent 65%); color: var(--color-cream);"
        >
          <p
            class="text-[0.8125rem] font-medium tracking-[0.18em] uppercase"
            style="color: var(--color-burgundy-300)"
          >
            Todor Aleksandrov
          </p>
          <h2
            class="font-display tracking-[-0.02em] mt-2"
            style="font-size:clamp(2rem, 4vw, 3rem); line-height:1.05;"
          >
            CS & Sommelier
          </h2>
          <p class="mt-2 text-sm" style="color: color-mix(in oklab, var(--color-cream) 80%, transparent);">
            Limerick, Ireland
          </p>
        </div>
      </div>

      <!-- LANGUAGES + CITIZENSHIP (top-right, spans 2 cols) -->
      <Card variant="surface" class="md:col-span-2 flex flex-col gap-3">
        <p class="eyebrow">Languages</p>
        <ul class="space-y-3 mt-1">
          <li class="flex items-baseline justify-between gap-3">
            <span class="font-display text-2xl tracking-[-0.01em]">English</span>
            <Tag variant="accent">C2</Tag>
          </li>
          <li class="flex items-baseline justify-between gap-3">
            <span class="font-display text-2xl tracking-[-0.01em]">Bulgarian</span>
            <Tag variant="accent">Native</Tag>
          </li>
        </ul>
        <div
          class="mt-auto pt-3 border-t flex items-center gap-2 text-xs"
          style="color: var(--text-soft); border-color: color-mix(in oklab, var(--text) 8%, transparent);"
        >
          <span aria-hidden="true">🇮🇪</span>
          <span>Irish citizen since summer 2025 · born 🇧🇬</span>
        </div>
        <p class="text-xs" style="color:var(--text-soft)">
          EFSET 76/100 · TRANSLIT interpreter since 2023
        </p>
      </Card>

      <!-- AT ADARE MANOR (right column, spans 2 cols) -->
      <Card variant="surface" class="md:col-span-2 flex flex-col gap-2">
        <p class="eyebrow">At Adare Manor</p>
        <h3 class="font-display text-2xl tracking-[-0.01em] mt-1">
          Junior Sommelier
        </h3>
        <p class="text-sm" style="color:var(--text-soft)">
          {sommelierRole && formatRange(
            sommelierRole.data.start,
            sommelierRole.data.end,
            sommelierRole.data.current,
          )}
        </p>
        <p class="text-sm leading-relaxed mt-2" style="color:var(--text-soft)">
          Wine pairing, upselling, strategic wine planning for events.
        </p>
        <a
          href="/sommelier"
          class="mt-auto pt-3 text-sm font-medium inline-flex items-center gap-1"
          style="color:var(--accent)"
        >
          The wine page
          <span aria-hidden="true">→</span>
        </a>
      </Card>

      <!-- BIO (full-width row) -->
      <Card variant="outline" padding="lg" class="md:col-span-6">
        <p class="eyebrow mb-4">Bio</p>
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 max-w-none">
          <p class="font-display text-xl md:text-2xl leading-snug tracking-[-0.01em]">
            Born in Bulgaria, moved to Ireland in 2015, now an Irish citizen and
            final-year Computer Science student at the University of Limerick —
            with a sommelier's apron in the wardrobe.
          </p>
          <p class="text-base leading-relaxed" style="color:var(--text-soft)">
            By day I'm a Temporary Associate Software Engineer at AMCS Group on
            the release side, with AI pair programming a real part of how I
            write production code. By evening I'm at Adare Manor's Carriage
            House pairing wines with the kitchen's tasting menus. Starting an
            MSc in AI &amp; Machine Learning at UL in September 2026 — going
            deeper on the side of the work I find most interesting.
          </p>
        </div>
      </Card>

      <!-- STAT: HOSPITALITY YEARS -->
      <Card variant="surface" class="md:col-span-2">
        <p class="eyebrow">Experience</p>
        <p class="font-display text-5xl mt-3 tracking-[-0.02em]" style="color:var(--accent)">
          {hospitalityYears.toFixed(1)}<span class="text-2xl ml-1" style="color:var(--text-soft)">yrs</span>
        </p>
        <p class="text-sm mt-2" style="color:var(--text-soft)">
          hospitality<br />
          <span class="text-xs">{softwareYears.toFixed(1)} yrs software</span>
        </p>
      </Card>

      <!-- STAT: CERTIFICATIONS -->
      <Card variant="surface" class="md:col-span-2">
        <p class="eyebrow">Certifications</p>
        <p class="font-display text-5xl mt-3 tracking-[-0.02em]" style="color:var(--accent)">
          {certifications.length}
        </p>
        <p class="text-sm mt-2" style="color:var(--text-soft)">
          across 5 areas
        </p>
        <a
          href="/certifications"
          class="mt-3 text-xs font-medium inline-flex items-center gap-1"
          style="color:var(--accent)"
        >
          See all <span aria-hidden="true">→</span>
        </a>
      </Card>

      <!-- FUN FACTS -->
      <Card variant="surface" class="md:col-span-2">
        <p class="eyebrow mb-3">Off-screen</p>
        <ul class="space-y-2 text-sm">
          {funFacts.map((fact) => (
            <li class="flex gap-2.5" style="color:var(--text)">
              <span style="color:var(--accent)" aria-hidden="true">•</span>
              <span>{fact}</span>
            </li>
          ))}
        </ul>
      </Card>

      <!-- EDUCATION (4 cols) -->
      <Card variant="surface" class="md:col-span-4 flex flex-col gap-5">
        <p class="eyebrow">Education</p>

        {ulBSc && (
          <div class="flex items-start gap-3">
            <Tag variant="soft">Now</Tag>
            <div class="flex-1 min-w-0">
              <h3 class="font-display text-xl tracking-[-0.01em] leading-tight">
                {ulBSc.data.degree}
              </h3>
              <p class="text-sm mt-1" style="color:var(--text-soft)">
                {ulBSc.data.institution} · {formatRange(ulBSc.data.start, ulBSc.data.end)}
              </p>
              {ulBSc.data.grade && (
                <p class="text-xs mt-2" style="color:var(--text-soft)">
                  {ulBSc.data.grade} · {ulBSc.data.activities}
                </p>
              )}
            </div>
          </div>
        )}

        {ulMSc && (
          <div class="flex items-start gap-3 pt-4 border-t" style="border-color: color-mix(in oklab, var(--text) 8%, transparent);">
            <Tag variant="accent">Next</Tag>
            <div class="flex-1 min-w-0">
              <h3 class="font-display text-xl tracking-[-0.01em] leading-tight">
                {ulMSc.data.degree}
              </h3>
              <p class="text-sm mt-1" style="color:var(--text-soft)">
                {ulMSc.data.institution} · starting {formatMonthYear(ulMSc.data.start, true)}
              </p>
              <p class="text-xs mt-2" style="color:var(--accent)">
                AI pair programming · model training · the deeper stack
              </p>
            </div>
          </div>
        )}
      </Card>

      <!-- LATEST CERTIFICATION -->
      <Card variant="surface" class="md:col-span-2">
        <p class="eyebrow mb-3">Latest cert</p>
        {latestCert && (
          <>
            <h3 class="font-display text-lg leading-tight tracking-[-0.01em]">
              {latestCert.data.title}
            </h3>
            <p class="text-sm mt-2" style="color:var(--text-soft)">
              {latestCert.data.issuer}
            </p>
            <p class="text-xs mt-1" style="color:var(--text-soft)">
              {formatMonthYear(latestCert.data.issued, true)}
            </p>
          </>
        )}
      </Card>
    </div>

    <!-- EDUCATION JOURNEY -->
    <section class="pt-12">
      <SectionHeader
        eyebrow="The long walk"
        title="Education, end to end"
        subtitle="Five schools across two countries, two languages, and twenty years of classrooms — primary in Bulgaria, finishing university in Ireland."
      />

      <ol class="mt-12 relative">
        <!-- Vertical rail -->
        <div
          aria-hidden="true"
          class="absolute left-[5px] top-2 bottom-2 w-px"
          style="background: linear-gradient(to bottom,
            color-mix(in oklab, var(--text) 15%, transparent) 0%,
            color-mix(in oklab, var(--text) 5%, transparent) 100%);"
        ></div>

        {educationJourney.map((entry, i) => {
          const isUpcoming = entry.data.status === "upcoming";
          const isCurrent = entry.data.status === "current";
          const dotColor = isUpcoming
            ? "var(--accent)"
            : isCurrent
              ? "var(--accent)"
              : "color-mix(in oklab, var(--text) 35%, transparent)";
          const dotFill = isUpcoming
            ? "var(--bg)"
            : isCurrent
              ? "var(--accent)"
              : "color-mix(in oklab, var(--text) 35%, transparent)";
          const dateRange = isUpcoming
            ? `${formatMonthYear(entry.data.start)} →`
            : formatRange(entry.data.start, entry.data.end);

          return (
            <li
              class="relative pl-8 sm:pl-10 py-5 border-b"
              style="border-color: color-mix(in oklab, var(--text) 6%, transparent);"
              data-reveal
            >
              <span
                class="absolute left-0 top-7 w-3 h-3 rounded-full border-2"
                style={`background:${dotFill}; border-color:${dotColor};`}
                aria-hidden="true"
              ></span>

              <div class="grid sm:grid-cols-[14rem_1fr] gap-3 sm:gap-8">
                <div>
                  <span
                    class="font-display text-3xl sm:text-4xl tabular-nums tracking-[-0.02em]"
                    style={`color: ${isCurrent || isUpcoming ? "var(--accent)" : "var(--text-soft)"};`}
                  >
                    0{educationJourney.length - i}
                  </span>
                  <p class="text-sm font-mono mt-1" style="color: var(--text-soft)">
                    {dateRange}
                  </p>
                </div>

                <div class="min-w-0">
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <h3 class="font-display text-xl sm:text-2xl tracking-[-0.01em]">
                      {entry.data.institution}
                    </h3>
                    {isCurrent && <Tag variant="soft">In progress</Tag>}
                    {isUpcoming && <Tag variant="accent">Upcoming</Tag>}
                  </div>
                  <p class="text-sm mt-1" style="color: var(--text)">
                    {entry.data.degree}
                  </p>
                  {entry.data.location && (
                    <p class="text-xs mt-1" style="color: var(--text-soft)">
                      {entry.data.location}
                    </p>
                  )}
                  {entry.data.grade && (
                    <p class="text-xs mt-2" style="color: var(--text-soft)">
                      <span class="font-medium" style="color: var(--text)">{entry.data.grade}</span>
                      {entry.data.activities && <> · {entry.data.activities}</>}
                    </p>
                  )}
                  {!entry.data.grade && entry.data.activities && (
                    <p class="text-xs mt-2" style="color: var(--text-soft)">
                      {entry.data.activities}
                    </p>
                  )}
                  {entry.data.note && (
                    <p class="text-sm mt-3 leading-relaxed max-w-2xl" style="color: var(--text-soft)">
                      {entry.data.note}
                    </p>
                  )}
                </div>
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    <!-- THREE TRADES -->
    <section class="pt-12">
      <SectionHeader
        eyebrow="Three trades"
        title="Wine. Water. Language."
        subtitle="Three identities that keep showing up alongside the software work — each with its own page."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <Card href="/sommelier" hover padding="lg" class="flex flex-col gap-3">
          <p class="eyebrow" style="color: var(--accent);">Trade · 01</p>
          <h3 class="font-display text-2xl tracking-[-0.01em]">Wine</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-soft)">
            Junior Sommelier at Adare Manor. CMS Intro · WSET Level 2 Merit. A
            33-dish pairing tool inside.
          </p>
          <p class="mt-auto pt-3 text-sm font-medium inline-flex items-center gap-1" style="color: var(--accent)">
            Open <span aria-hidden="true">→</span>
          </p>
        </Card>
        <Card href="/water" hover padding="lg" class="flex flex-col gap-3">
          <p class="eyebrow" style="color: var(--accent);">Trade · 02</p>
          <h3 class="font-display text-2xl tracking-[-0.01em]">Water</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-soft)">
            Learnt to swim properly in 2024. Ten safety certs and a Portugal
            training camp later, now teaching it. Interactive emergency-scenario
            tool inside.
          </p>
          <p class="mt-auto pt-3 text-sm font-medium inline-flex items-center gap-1" style="color: var(--accent)">
            Open <span aria-hidden="true">→</span>
          </p>
        </Card>
        <Card href="/language" hover padding="lg" class="flex flex-col gap-3">
          <p class="eyebrow" style="color: var(--accent);">Trade · 03</p>
          <h3 class="font-display text-2xl tracking-[-0.01em]">Language</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-soft)">
            Bilingual EN / BG, C2 in both, interpreter with TRANSLIT. A
            thirty-phrase Bulgarian phrasebook inside.
          </p>
          <p class="mt-auto pt-3 text-sm font-medium inline-flex items-center gap-1" style="color: var(--accent)">
            Open <span aria-hidden="true">→</span>
          </p>
        </Card>
      </div>
    </section>

    <!-- VALUES / WORKING STYLE -->
    <section class="pt-12">
      <SectionHeader
        eyebrow="Working style"
        title="What I'm trying to be good at"
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <Card variant="outline" padding="lg">
          <p class="eyebrow mb-2">01</p>
          <h3 class="font-display text-xl tracking-[-0.01em]">
            Attention to detail
          </h3>
          <p class="text-sm mt-3 leading-relaxed" style="color:var(--text-soft)">
            Whether it's a misaligned form input or a wine that's a few degrees
            off — small things compound.
          </p>
        </Card>
        <Card variant="outline" padding="lg">
          <p class="eyebrow mb-2">02</p>
          <h3 class="font-display text-xl tracking-[-0.01em]">
            Clear communication
          </h3>
          <p class="text-sm mt-3 leading-relaxed" style="color:var(--text-soft)">
            Tutoring CS first-years, interpreting in clinics, briefing guests on
            a tasting menu — translation is half the job.
          </p>
        </Card>
        <Card variant="outline" padding="lg">
          <p class="eyebrow mb-2">03</p>
          <h3 class="font-display text-xl tracking-[-0.01em]">
            Calm under pressure
          </h3>
          <p class="text-sm mt-3 leading-relaxed" style="color:var(--text-soft)">
            Poolside lifeguard rotations, a busy fine-dining floor, and release
            branches that need merging before 5pm.
          </p>
        </Card>
      </div>
    </section>

    <!-- ACTION ROW -->
    <div class="flex flex-wrap gap-3 pt-4">
      <Button href="/experience" arrow>Full experience</Button>
      <Button href="/projects" variant="outline" arrow>See my work</Button>
      <Button href="/contact" variant="ghost" arrow>Get in touch</Button>
    </div>
  </Container>
</BaseLayout>
