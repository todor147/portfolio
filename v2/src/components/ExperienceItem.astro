---
import Tag from "./Tag.astro";
import { formatRange, diffMonths, formatDuration } from "../lib/dates";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"experience">;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const months = data.current
  ? diffMonths(data.start, `${new Date().getFullYear()}-${String(new Date().getMonth() + 1).padStart(2, "0")}`)
  : data.end
    ? diffMonths(data.start, data.end)
    : 0;

const categoryLabels: Record<string, string> = {
  software: "Software",
  hospitality: "Hospitality",
  education: "Education",
  lifeguarding: "Lifeguarding",
  interpretation: "Languages",
  delivery: "Delivery",
  other: "Other",
};

const searchHaystack = [
  data.title,
  data.employer,
  data.summary,
  data.location ?? "",
  categoryLabels[data.category] ?? "",
].join(" ").toLowerCase();
---

<details
  id={entry.id}
  class="experience-item group/exp relative pl-8 sm:pl-10 py-4 border-b transition-all"
  style="border-color: color-mix(in oklab, var(--text) 8%, transparent)"
  data-category={data.category}
  data-search={searchHaystack}
>
  <!-- Timeline marker -->
  <span
    class="absolute left-0 top-7 w-3 h-3 rounded-full border-2 transition-all"
    style="background:var(--bg); border-color:var(--accent);"
    aria-hidden="true"
  ></span>

  <summary class="list-none cursor-pointer flex items-baseline justify-between gap-4 flex-wrap">
    <div class="min-w-0 flex-1">
      <div class="flex items-baseline gap-3 flex-wrap">
        <h3 class="font-display text-xl sm:text-2xl tracking-[-0.01em]">
          {data.title}
        </h3>
        {data.current && (
          <Tag variant="soft">Current</Tag>
        )}
        {data.featured && !data.current && (
          <Tag variant="accent">Featured</Tag>
        )}
      </div>
      <p class="text-sm mt-1" style="color:var(--text-soft)">
        {data.employer}{data.location ? <span class="opacity-60"> · {data.location}</span> : ""}
      </p>
    </div>
    <div class="text-right whitespace-nowrap flex flex-col items-end gap-1 shrink-0">
      <span class="font-mono text-xs tabular-nums" style="color:var(--text)">
        {formatRange(data.start, data.end, data.current)}
      </span>
      <span class="text-xs" style="color:var(--text-soft)">
        {formatDuration(months)} · {categoryLabels[data.category] ?? data.category}
      </span>
    </div>
    <span
      class="exp-chevron text-xs px-2 py-1 rounded-full border transition-transform group-open/exp:rotate-180 sm:hidden"
      style="border-color: color-mix(in oklab, var(--text) 15%, transparent); color: var(--text-soft);"
      aria-hidden="true"
    >▾</span>
  </summary>

  <div class="mt-4 sm:ml-1 pl-0 sm:pl-0 text-sm leading-relaxed max-w-3xl space-y-3" style="color:var(--text-soft)">
    <p class="font-medium" style="color:var(--text)">{data.summary}</p>
    <div class="prose-content">
      <Content />
    </div>
  </div>
</details>

<style>
  details.experience-item summary::-webkit-details-marker {
    display: none;
  }
  details.experience-item summary::marker {
    content: "";
  }
  details.experience-item summary {
    transition: padding 200ms ease;
  }
  details.experience-item:hover summary h3 {
    color: var(--accent);
    transition: color 200ms ease;
  }
  details.experience-item[open] {
    padding-bottom: 1.5rem;
  }
  details.experience-item .prose-content :global(p) {
    margin-top: 0.5rem;
  }
  details.experience-item .prose-content :global(p:first-child) {
    margin-top: 0;
  }
</style>
