---
import Card from "./Card.astro";
import Tag from "./Tag.astro";
import Picture from "./Picture.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  size?: "default" | "feature";
}

const { project, size = "default" } = Astro.props;
const { data, id } = project;
const showAllStack = size === "feature";
const visibleStack = showAllStack ? data.stack : data.stack.slice(0, 3);
---

<Card
  href={`/projects/${id}`}
  hover
  padding="none"
  class="overflow-hidden flex flex-col group/card"
  data-project-tags={data.tags.join(",")}
  data-reveal
>
  {data.image && (
    <div
      class:list={[
        "overflow-hidden bg-[color-mix(in_oklab,var(--text)_5%,transparent)]",
        size === "feature" ? "aspect-[16/10]" : "aspect-[4/3]",
      ]}
    >
      <Picture
        src={data.image}
        alt={data.title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-105"
      />
    </div>
  )}
  <div class="p-6 flex flex-col flex-1">
    <div class="flex flex-wrap gap-1.5 mb-3">
      {visibleStack.map((tech) => <Tag>{tech}</Tag>)}
      {!showAllStack && data.stack.length > 3 && (
        <Tag>+{data.stack.length - 3}</Tag>
      )}
    </div>
    <h3
      class:list={[
        "font-display tracking-[-0.01em] mb-2",
        size === "feature" ? "text-3xl" : "text-2xl",
      ]}
    >
      {data.title}
    </h3>
    <p class="text-sm leading-relaxed flex-1" style="color:var(--text-soft)">
      {data.tagline}
    </p>
    <p
      class="mt-4 text-sm font-medium inline-flex items-center gap-1"
      style="color:var(--accent)"
    >
      View case study
      <span class="transition-transform duration-300 group-hover/card:translate-x-1" aria-hidden="true">→</span>
    </p>
  </div>
</Card>
