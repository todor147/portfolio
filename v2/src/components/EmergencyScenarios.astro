---
import { getCollection } from "astro:content";
import Tag from "./Tag.astro";

const scenarios = await getCollection("scenarios");
const sorted = scenarios.sort((a, b) => {
  // critical → urgent → serious, then alphabetical within
  const order = { critical: 0, urgent: 1, serious: 2 };
  const sevDiff = order[a.data.severity] - order[b.data.severity];
  if (sevDiff !== 0) return sevDiff;
  return a.data.title.localeCompare(b.data.title);
});
const initial = sorted[0];

const severityColors: Record<string, string> = {
  critical: "#DC2626",
  urgent: "#EA580C",
  serious: "#CA8A04",
};

const severityLabels: Record<string, string> = {
  critical: "Life-threatening",
  urgent: "Urgent",
  serious: "Serious",
};
---

<section
  id="scenarios-tool"
  class="relative overflow-hidden rounded-[2rem] p-8 md:p-12 lg:p-14"
  style="
    background: linear-gradient(160deg, #0F2A3D 0%, #1B3D5A 100%);
    color: #E8F0F5;
  "
>
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.05] pointer-events-none mix-blend-overlay"
    style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 4px 4px;"
  >
  </div>

  <div class="relative">
    <p
      class="text-[0.8125rem] font-medium tracking-[0.18em] uppercase"
      style="color: #7DB4D8;"
    >
      The first 60 seconds
    </p>
    <h2
      class="font-display tracking-[-0.02em] mt-3"
      style="font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.05; color: #FFFFFF;"
    >
      What would you do?
    </h2>
    <p class="mt-3 text-lg max-w-2xl" style="color: rgba(232, 240, 245, 0.78)">
      Ten scenarios drawn from PHECC First Aid Responder and Cardiac First Response training.
      Pick one — see the structured response a trained first aider should take.
    </p>

    <!-- CONTROLS -->
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <label for="scenario-select" class="sr-only">Choose a scenario</label>
      <div class="relative flex-1 min-w-[18rem]">
        <select
          id="scenario-select"
          class="appearance-none w-full rounded-full pl-5 pr-12 py-3.5 text-base font-medium tracking-wide bg-transparent border focus:outline-none focus:ring-2 focus:ring-offset-2 cursor-pointer transition-colors"
          style="border-color: rgba(232, 240, 245, 0.35); color: #FFFFFF; --tw-ring-color: #7DB4D8; --tw-ring-offset-color: #0F2A3D;"
        >
          {sorted.map((s) => (
            <option value={s.id} style="color: #1A1614; background: #FAF6F0;">
              {s.data.title}
            </option>
          ))}
        </select>
        <span
          aria-hidden="true"
          class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none"
          style="color: #7DB4D8;"
        >▾</span>
      </div>
      <button
        id="scenario-random"
        type="button"
        class="rounded-full px-5 py-3.5 font-medium border transition-colors"
        style="border-color: rgba(232, 240, 245, 0.35); color: #FFFFFF;"
      >
        Random scenario ⤳
      </button>
    </div>

    <!-- RESULT CARDS -->
    <div id="scenario-results" class="mt-8">
      {sorted.map((s) => (
        <article
          data-scenario-id={s.id}
          hidden={s.id !== initial.id}
          class="rounded-2xl p-6 md:p-8"
          style="background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.12);"
        >
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <h3
              class="font-display"
              style="font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.15; letter-spacing: -0.01em; color: #FFFFFF; max-width: 36rem;"
            >
              {s.data.title}
            </h3>
            <span
              class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] whitespace-nowrap"
              style={`background: ${severityColors[s.data.severity]}; color: #FFFFFF;`}
            >
              <span
                class="inline-block w-1.5 h-1.5 rounded-full"
                style="background: #FFFFFF;"
                aria-hidden="true"></span>
              {severityLabels[s.data.severity]}
            </span>
          </div>

          <!-- DANGER -->
          <div
            class="mt-5 p-4 rounded-xl border-l-4 flex gap-3"
            style="background: rgba(220, 38, 38, 0.12); border-color: #DC2626;"
          >
            <span aria-hidden="true" class="text-xl leading-none mt-0.5">⚠</span>
            <div>
              <p
                class="text-[0.7rem] font-semibold tracking-[0.18em] uppercase"
                style="color: #FCA5A5;"
              >
                Danger
              </p>
              <p class="text-sm mt-1 leading-relaxed" style="color: rgba(255,255,255,0.92);">
                {s.data.danger}
              </p>
            </div>
          </div>

          <!-- RESPONSE STEPS -->
          <div class="mt-6">
            <p
              class="text-[0.7rem] font-semibold tracking-[0.18em] uppercase mb-3"
              style="color: #7DB4D8;"
            >
              Response — first 60 seconds
            </p>
            <ol class="space-y-3">
              {s.data.response.map((step, i) => (
                <li class="flex gap-3 items-start">
                  <span
                    class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full font-mono text-xs tabular-nums"
                    style="background: rgba(125, 180, 216, 0.18); color: #7DB4D8; border: 1px solid rgba(125, 180, 216, 0.35);"
                  >
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <p class="text-sm md:text-base leading-relaxed flex-1" style="color: rgba(232, 240, 245, 0.92);">
                    {step}
                  </p>
                </li>
              ))}
            </ol>
          </div>

          <!-- SKILLS + CALLOUT -->
          <div class="mt-6 grid md:grid-cols-2 gap-5">
            <div>
              <p
                class="text-[0.7rem] font-semibold tracking-[0.18em] uppercase mb-2"
                style="color: rgba(232, 240, 245, 0.55);"
              >
                Skills required
              </p>
              <div class="flex flex-wrap gap-1.5">
                {s.data.skills.map((skill) => (
                  <span
                    class="inline-flex items-center rounded-full px-2.5 py-1 text-[0.7rem] font-medium tracking-[0.04em] uppercase border"
                    style="border-color: rgba(232, 240, 245, 0.25); color: rgba(232, 240, 245, 0.85);"
                  >
                    {skill}
                  </span>
                ))}
              </div>
            </div>
            {s.data.callout && (
              <div>
                <p
                  class="text-[0.7rem] font-semibold tracking-[0.18em] uppercase mb-2"
                  style="color: rgba(232, 240, 245, 0.55);"
                >
                  Worth remembering
                </p>
                <p class="text-sm italic leading-relaxed" style="color: rgba(232, 240, 245, 0.88);">
                  {s.data.callout}
                </p>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- DISCLAIMER -->
    <p
      class="mt-6 text-xs leading-relaxed max-w-3xl"
      style="color: rgba(232, 240, 245, 0.55);"
    >
      <strong style="color: rgba(232, 240, 245, 0.75)">Educational summary only.</strong>
      These are condensed versions of PHECC-aligned protocols from FAR and CFR-A training current as of 2026. They are not a substitute for accredited first-aid training. In a real emergency, call 112 (Ireland) or 999 (UK / Ireland) and follow the dispatcher's instructions.
    </p>
  </div>
</section>

<script>
  const select = document.getElementById("scenario-select") as HTMLSelectElement | null;
  const random = document.getElementById("scenario-random") as HTMLButtonElement | null;
  const cards = document.querySelectorAll<HTMLElement>("[data-scenario-id]");

  function show(id: string) {
    cards.forEach((card) => {
      card.hidden = card.dataset.scenarioId !== id;
    });
  }

  select?.addEventListener("change", () => show(select.value));

  random?.addEventListener("click", () => {
    if (!select) return;
    let pick = select.value;
    let attempts = 0;
    while (pick === select.value && attempts < 10) {
      pick = select.options[Math.floor(Math.random() * select.options.length)].value;
      attempts++;
    }
    select.value = pick;
    show(pick);
    document.getElementById("scenario-results")?.scrollIntoView({
      behavior: "smooth",
      block: "nearest",
    });
  });
</script>
