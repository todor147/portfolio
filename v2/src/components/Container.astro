---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  size?: "default" | "narrow" | "wide";
}

const { as: Tag = "div", class: className = "", size = "default" } = Astro.props;

const maxWidth = {
  narrow: "max-w-3xl",
  default: "max-w-7xl",
  wide: "max-w-[88rem]",
}[size];
---

<Tag class:list={["w-full mx-auto px-5 sm:px-8 lg:px-10", maxWidth, className]}>
  <slot />
</Tag>
