---
import Container from "./Container.astro";
import Button from "./Button.astro";
import Picture from "./Picture.astro";
---

<section class="relative pt-12 pb-20 md:pt-20 md:pb-28 overflow-hidden">
  <!-- Subtle background ornament -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:
      radial-gradient(60% 50% at 15% 0%, color-mix(in oklab, var(--accent) 8%, transparent), transparent 70%),
      radial-gradient(50% 40% at 95% 30%, color-mix(in oklab, var(--accent) 5%, transparent), transparent 70%);"
  >
  </div>

  <Container size="wide">
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-10 md:gap-16 items-center">
      <!-- TEXT COLUMN -->
      <div class="space-y-8 md:space-y-10" data-reveal>
        <p class="eyebrow">Portfolio · 2026</p>

        <h1
          class="font-display tracking-[-0.03em] leading-[0.98]"
          style="font-size:clamp(3.5rem, 9vw, 7rem)"
        >
          <span class="block">Todor</span>
          <span class="block" style="color:var(--accent)">Aleksandrov</span>
        </h1>

        <div class="flex items-center gap-4">
          <span class="h-px flex-shrink-0 w-12" style="background:color-mix(in oklab, var(--text) 25%, transparent)"></span>
          <p
            class="font-display italic text-xl md:text-2xl"
            style="color:var(--text-soft)"
          >
            Computer Science <span style="color:var(--accent)">·</span> Sommelier
          </p>
        </div>

        <p
          class="text-lg md:text-xl leading-relaxed max-w-xl"
          style="color:var(--text)"
        >
          Currently shipping releases at <a
            href="/experience#amcs-temp-associate-software-engineer"
            class="underline decoration-burgundy-300 underline-offset-4 hover:decoration-burgundy-600 transition-colors">AMCS Group</a
          > while pouring fine wines at
          <a
            href="/sommelier"
            class="underline decoration-burgundy-300 underline-offset-4 hover:decoration-burgundy-600 transition-colors">Adare Manor</a
          >. BSc Computer Science graduate (UL, 2026) — starting MSc AI & Machine Learning in September 2026.
        </p>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <Button href="/projects" arrow magnetic>View work</Button>
          <Button href="/contact" variant="outline">Get in touch</Button>
          <Button
            href="/cv"
            variant="ghost"
            ariaLabel="View and download Todor Aleksandrov's CV"
          >View CV</Button>
        </div>

        <ul
          class="flex flex-wrap gap-x-6 gap-y-2 pt-4 text-sm"
          style="color:var(--text-soft)"
        >
          <li class="inline-flex items-center gap-2">
            <span
              class="inline-block w-1.5 h-1.5 rounded-full"
              style="background:var(--accent)"
              aria-hidden="true"></span>
            Limerick, Ireland
          </li>
          <li class="inline-flex items-center gap-2">
            <span
              class="inline-block w-1.5 h-1.5 rounded-full"
              style="background:#22c55e"
              aria-hidden="true"></span>
            Open to graduate roles from 2027
          </li>
          <li class="inline-flex items-center gap-2">
            <span aria-hidden="true">🇮🇪</span>
            Irish citizen since 2025
          </li>
          <li class="inline-flex items-center gap-2">
            <span aria-hidden="true">·</span>
            EN · BG (C2 / native)
          </li>
        </ul>
      </div>

      <!-- PORTRAIT COLUMN -->
      <div class="relative order-first lg:order-last" data-reveal data-reveal-delay="120">
        <!-- Decorative frame -->
        <div
          aria-hidden="true"
          class="absolute -inset-4 -z-10 rounded-[2.5rem] rotate-[-2deg]"
          style="background:color-mix(in oklab, var(--accent) 12%, transparent)"
        >
        </div>

        <div
          class="relative aspect-[4/5] max-w-[28rem] mx-auto rounded-[2rem] overflow-hidden border"
          style="border-color:color-mix(in oklab, var(--text) 12%, transparent)"
        >
          <Picture
            src="profile pic.jpg"
            alt="Todor Aleksandrov"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <!-- Floating signature card -->
        <div
          class="hidden md:block absolute -bottom-6 left-6 rounded-2xl px-5 py-4 backdrop-blur-md"
          style="background:color-mix(in oklab, var(--bg) 70%, transparent); border:1px solid color-mix(in oklab, var(--text) 15%, transparent); box-shadow: 0 12px 32px color-mix(in oklab, var(--text) 12%, transparent);"
        >
          <p class="eyebrow mb-1">Currently</p>
          <p class="font-display text-lg leading-tight">Junior Sommelier</p>
          <p class="text-xs mt-0.5" style="color:var(--text-soft)">Adare Manor · since 2024</p>
        </div>
      </div>
    </div>
  </Container>
</section>
